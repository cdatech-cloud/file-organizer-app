<Window x:Class="FileOrganizerApp.Views.TasksWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Manage Tasks" Height="600" Width="900" 
        WindowStartupLocation="CenterOwner" ShowInTaskbar="False">
    <Grid>
        <StackPanel Margin="15">
            <TextBlock FontSize="16" FontWeight="Bold" Text="Pending Tasks" Margin="0,0,0,15"/>
            
            <StackPanel Orientation="Horizontal" Margin="0,0,0,15">
                <Button Name="ExecuteAllButton" Content="Execute All Tasks" 
                        Click="ExecuteAll_Click" Width="130" 
                        Background="#27AE60" Foreground="White"/>
                <Button Name="DeleteTaskButton" Content="Delete Task" 
                        Click="DeleteTask_Click" Width="110" Margin="10,0,0,0"
                        Background="#E74C3C" Foreground="White"/>
                <Button Name="ClearAllButton" Content="Clear All Tasks" 
                        Click="ClearAll_Click" Width="120" Margin="10,0,0,0"
                        Background="#E67E22" Foreground="White"/>
            </StackPanel>

            <TextBlock FontSize="12" FontWeight="Bold" Text="Tasks:" Margin="0,0,0,10"/>
            
            <ListView Name="TasksListView" Height="400">
                <ListView.View>
                    <GridView>
                        <GridViewColumn Header="File/Folder" Width="200" DisplayMemberBinding="{Binding DisplayName}"/>
                        <GridViewColumn Header="Action" Width="80" DisplayMemberBinding="{Binding Action}"/>
                        <GridViewColumn Header="Subject (Full Path)" Width="300" DisplayMemberBinding="{Binding Subject}"/>
                        <GridViewColumn Header="Destination" Width="200" DisplayMemberBinding="{Binding Destination}"/>
                        <GridViewColumn Header="Status" Width="80" DisplayMemberBinding="{Binding Status}"/>
                    </GridView>
                </ListView.View>
            </ListView>

            <StackPanel Orientation="Horizontal" Margin="0,15,0,0" HorizontalAlignment="Right">
                <Button Content="Close" Click="Close_Click" Width="80" Background="#95A5A6" Foreground="White"/>
            </StackPanel>
        </StackPanel>
    </Grid>
</Window>
