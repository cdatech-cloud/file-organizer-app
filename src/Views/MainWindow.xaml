<Window x:Class="FileOrganizerApp.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="File Organizer" Height="700" Width="1000" WindowStartupLocation="CenterScreen">
    <Grid Background="#F8F9FA">
        <DockPanel>
            <Menu DockPanel.Dock="Top" Background="White" BorderBrush="#E0E0E0" BorderThickness="0,0,0,1">
                <MenuItem Header="File" FontSize="12">
                    <MenuItem Header="Scan Settings" Click="ScanSettings_Click"/>
                    <Separator/>
                    <MenuItem Header="Exit" Click="Exit_Click"/>
                </MenuItem>
                <MenuItem Header="Categories" Click="CategoryManager_Click" FontSize="12"/>
                <MenuItem Header="Tasks" Click="ViewTasks_Click" FontSize="12"/>
            </Menu>
            <TabControl DockPanel.Dock="Top" Margin="0" Padding="0" Background="#F8F9FA">
                <TabItem Header="File Organization" IsSelected="True" Background="White" Margin="15,8">
                    <StackPanel Margin="20,20,20,20" Background="White">
                        <TextBlock FontSize="18" FontWeight="SemiBold" Text="Organize Your Files" Margin="0,0,0,20" Foreground="#2C3E50"/>
                        <TextBlock FontSize="12" Text="Select a folder to scan and organize files by category" Margin="0,0,0,15" Foreground="#7F8C8D"/>
                        
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,20">
                            <Button Content="Start Scan" Width="140" Height="40" Click="StartScan_Click" 
                                    Background="#2ECC71" Foreground="White" FontSize="12" FontWeight="SemiBold"
                                    Cursor="Hand" Padding="10,0"/>
                            <Button Content="Schedule Scan" Width="140" Height="40" Click="ScheduleScan_Click" Margin="15,0,0,0" 
                                    Background="#3498DB" Foreground="White" FontSize="12" FontWeight="SemiBold"
                                    Cursor="Hand" Padding="10,0"/>
                        </StackPanel>

                        <TextBlock FontSize="12" FontWeight="SemiBold" Text="Recent File List" Margin="0,10,0,10" Foreground="#2C3E50"/>
                        <ListView Name="FileListView" Margin="0,0,0,0" Height="350" Background="White" BorderBrush="#ECF0F1" BorderThickness="1">
                            <ListView.View>
                                <GridView>
                                    <GridViewColumn Header="File Name" Width="400" DisplayMemberBinding="{Binding FileName}"/>
                                    <GridViewColumn Header="Path" Width="500" DisplayMemberBinding="{Binding FilePath}"/>
                                </GridView>
                            </ListView.View>
                        </ListView>
                    </StackPanel>
                </TabItem>
                <TabItem Header="Scan Results" Name="ScanResultsTab" Background="White" Margin="15,8">
                    <StackPanel Margin="20,20,20,20" Background="White">
                        <Border Margin="0,0,0,15" Padding="12" Background="#ECF0F1">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock VerticalAlignment="Center" Text="Scanned Path: " FontWeight="SemiBold" Foreground="#2C3E50" FontSize="12"/>
                                <TextBlock Name="ScannedPathTextBlock" VerticalAlignment="Center" Margin="5,0,0,0" TextWrapping="Wrap" Foreground="#34495E" FontSize="12"/>
                            </StackPanel>
                        </Border>
                        
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,15">
                            <Button Content="Rescan" Click="RescanButton_Click" Width="120" Height="38"
                                    Background="#3498DB" Foreground="White" FontSize="12" FontWeight="SemiBold"
                                    Cursor="Hand" Padding="10,0"/>
                        </StackPanel>

                        <TextBlock FontSize="14" FontWeight="SemiBold" Text="Items in Directory" Margin="0,0,0,10" Foreground="#2C3E50"/>
                        
                        <ListView Name="ItemsListView" Height="320" SelectionChanged="ItemsListView_SelectionChanged" 
                                  Background="White" BorderBrush="#ECF0F1" BorderThickness="1">
                            <ListView.View>
                                <GridView>
                                    <GridViewColumn Header="Name" Width="350" DisplayMemberBinding="{Binding Name}"/>
                                    <GridViewColumn Header="Type" Width="120" DisplayMemberBinding="{Binding Type}"/>
                                    <GridViewColumn Header="Full Path" Width="380" DisplayMemberBinding="{Binding FullPath}"/>
                                </GridView>
                            </ListView.View>
                        </ListView>

                        <TextBlock Name="ItemCountTextBlock" Margin="0,15,0,0" FontSize="11" Foreground="#7F8C8D" FontWeight="SemiBold"/>
                    </StackPanel>
                </TabItem>
            </TabControl>
        </DockPanel>
    </Grid>
</Window>