<Window x:Class="FileOrganizerApp.Views.CategoryManagementWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Category Management" Height="500" Width="700" 
        WindowStartupLocation="CenterOwner" ShowInTaskbar="False">
    <Grid>
        <StackPanel Margin="15">
            <TextBlock FontSize="16" FontWeight="Bold" Text="Manage Categories" Margin="0,0,0,15"/>
            
            <StackPanel Orientation="Horizontal" Margin="0,0,0,15">
                <Button Name="AddCategoryButton" Content="Add Category" 
                        Click="AddCategory_Click" Width="100" 
                        Background="#2ECC71" Foreground="White"/>
                <Button Name="EditCategoryButton" Content="Edit Category" 
                        Click="EditCategory_Click" Width="100" Margin="10,0,0,0"
                        Background="#3498DB" Foreground="White"/>
                <Button Name="DeleteCategoryButton" Content="Delete Category" 
                        Click="DeleteCategory_Click" Width="120" Margin="10,0,0,0"
                        Background="#E67E22" Foreground="White"/>
            </StackPanel>

            <TextBlock FontSize="12" FontWeight="Bold" Text="Categories:" Margin="0,0,0,10"/>
            
            <ListView Name="CategoriesListView" Height="350">
                <ListView.View>
                    <GridView>
                        <GridViewColumn Header="Category Name" Width="250" DisplayMemberBinding="{Binding Name}"/>
                        <GridViewColumn Header="Location (Target Path)" Width="400" DisplayMemberBinding="{Binding TargetPath}"/>
                    </GridView>
                </ListView.View>
            </ListView>

            <StackPanel Orientation="Horizontal" Margin="0,15,0,0" HorizontalAlignment="Right">
                <Button Content="Close" Click="Close_Click" Width="80" Background="#BDC3C7" Foreground="White"/>
            </StackPanel>
        </StackPanel>
    </Grid>
</Window>
