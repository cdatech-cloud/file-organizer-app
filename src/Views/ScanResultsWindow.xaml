<Window x:Class="FileOrganizerApp.Views.ScanResultsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Scan Results" Height="500" Width="700" WindowStartupLocation="CenterScreen">
    <Grid>
        <StackPanel Margin="10">
            <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                <TextBlock VerticalAlignment="Center" Text="Scanned Path: " FontWeight="Bold"/>
                <TextBlock VerticalAlignment="Center" Text="{Binding ScannedPath}" Margin="5,0,0,0" TextWrapping="Wrap"/>
            </StackPanel>
            
            <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                <Button Content="Rescan" Click="RescanButton_Click" Width="80"/>
                <Button Content="Close" Click="CloseButton_Click" Width="80" Margin="5,0,0,0"/>
            </StackPanel>

            <TextBlock FontSize="14" FontWeight="Bold" Text="Direct Children" Margin="0,0,0,5"/>
            
            <ListView Name="ItemsListView" Height="350" MouseDoubleClick="ItemsListView_MouseDoubleClick">
                <ListView.View>
                    <GridView>
                        <GridViewColumn Header="Name" Width="350" DisplayMemberBinding="{Binding Name}"/>
                        <GridViewColumn Header="Type" Width="100" DisplayMemberBinding="{Binding Type}"/>
                        <GridViewColumn Header="Full Path" Width="200" DisplayMemberBinding="{Binding FullPath}"/>
                    </GridView>
                </ListView.View>
            </ListView>

            <TextBlock Margin="0,10,0,0" Text="{Binding ItemCount}" FontSize="12" Foreground="Gray"/>
        </StackPanel>
    </Grid>
</Window>
