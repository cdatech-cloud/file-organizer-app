<Window x:Class="FileOrganizerApp.Views.SelectCategoryDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Select a Category" Height="300" Width="400" 
        WindowStartupLocation="CenterOwner" ShowInTaskbar="False" ResizeMode="NoResize">
    <Grid Background="#F5F5F5">
        <StackPanel Margin="20" VerticalAlignment="Stretch">
            <TextBlock FontSize="14" FontWeight="Bold" Margin="0,0,0,15">
                Select a category for this item:
            </TextBlock>

            <ListBox Name="CategoriesListBox" Height="180" Margin="0,0,0,15" 
                     DisplayMemberPath="Name" SelectedValuePath="." MouseDoubleClick="CategoriesListBox_MouseDoubleClick"/>

            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Name="OkButton" Content="OK" Click="Ok_Click" 
                        Height="35" Width="80" Margin="0,0,10,0"
                        Background="#2ECC71" Foreground="White"/>
                <Button Name="CancelButton" Content="Cancel" Click="Cancel_Click" 
                        Height="35" Width="80"
                        Background="#BDC3C7" Foreground="White"/>
            </StackPanel>
        </StackPanel>
    </Grid>
</Window>
